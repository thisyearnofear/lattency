{
  "name": "lattency",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx scripts/gen-speedtest-blobs.ts && next dev",
    "build": "tsx scripts/gen-speedtest-blobs.ts && next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "migrate": "tsx scripts/migrate.ts",
    "seed": "tsx scripts/seed.ts",
    "db:check": "tsx scripts/db-check.ts",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix --max-warnings 0"
    ],
    "*.{ts,tsx,js,jsx,json,md,mdx,yml,yaml,sh,sql,env,toml,html,css}": [
      "secretlint --maskSecrets"
    ]
  },
  "dependencies": {
    "@auth/pg-adapter": "1.11.2",
    "@gsap/react": "2.1.2",
    "dotenv": "17.4.2",
    "gsap": "3.15.0",
    "leaflet": "1.9.4",
    "next": "16.3.0-preview.5",
    "next-auth": "5.0.0-beta.31",
    "pg": "8.22.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "resend": "6.16.0"
  },
  "devDependencies": {
    "@secretlint/secretlint-rule-preset-recommend": "13.0.2",
    "@tailwindcss/postcss": "^4",
    "@types/leaflet": "1.9.21",
    "@types/node": "^20",
    "@types/pg": "8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "4.1.9",
    "eslint": "^9",
    "eslint-config-next": "16.3.0-preview.5",
    "husky": "9.1.7",
    "lint-staged": "17.0.8",
    "playwright": "1.61.1",
    "secretlint": "13.0.2",
    "tailwindcss": "^4",
    "tsx": "4.22.4",
    "typescript": "^5",
    "vitest": "4.1.9"
  },
  "packageManager": "pnpm@10.33.2"
}
